{
  "name": "big-log-viewer",
  "displayName": "大日志文件查看器",
  "description": "专业的大日志文件查看和处理工具，支持虚拟滚动、智能搜索、时间过滤、级别过滤、折叠重复日志等功能",
  "version": "1.2.7",
  "license": "MIT",
  "publisher": "wake",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/uwakeme/large_log_check"
  },
  "keywords": [
    "log",
    "log viewer",
    "large file",
    "日志",
    "日志查看",
    "大文件",
    "日志分析"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Formatters"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "big-log-viewer.openLogFile",
        "title": "打开大日志文件",
        "category": "日志查看器"
      },
      {
        "command": "big-log-viewer.deleteByTime",
        "title": "按时间删除日志",
        "category": "日志查看器"
      },
      {
        "command": "big-log-viewer.deleteByLine",
        "title": "按行数删除日志",
        "category": "日志查看器"
      },
      {
        "command": "big-log-viewer.refresh",
        "title": "刷新日志文件",
        "category": "日志查看器"
      },
      {
        "command": "big-log-viewer.showStatistics",
        "title": "显示日志统计",
        "category": "日志查看器"
      },
      {
        "command": "big-log-viewer.toggleBookmarks",
        "title": "书签管理",
        "category": "日志查看器"
      },
      {
        "command": "big-log-viewer.toggleComments",
        "title": "注释管理",
        "category": "日志查看器"
      },
      {
        "command": "big-log-viewer.jumpToLine",
        "title": "跳转到行号",
        "category": "日志查看器"
      },
      {
        "command": "big-log-viewer.showAdvancedSearch",
        "title": "高级搜索",
        "category": "日志查看器"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .log || resourceExtname == .txt",
          "command": "big-log-viewer.openLogFile",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "resourceExtname == .log || resourceExtname == .txt",
          "command": "big-log-viewer.openLogFile",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "大日志文件查看器",
      "properties": {
        "big-log-viewer.search.debounceMs": {
          "type": "number",
          "default": 400,
          "minimum": 0,
          "description": "搜索框输入后自动触发搜索的防抖时间（毫秒）。"
        },
        "big-log-viewer.collapse.minRepeatCount": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "折叠重复日志时，至少重复多少次才会被折叠。"
        },
        "big-log-viewer.timeline.samplePoints": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "maximum": 1000,
          "description": "时间线采样点数量，数值越大越精细但计算时间越长。"
        },
        "big-log-viewer.theme": {
          "type": "string",
          "enum": [
            "default",
            "neon",
            "aurora",
            "holo"
          ],
          "default": "default",
          "enumDescriptions": [
            "默认主题(跟随 VSCode 当前主题)",
            "NEON.CYBER — 赛博朋克终端(纯黑+霓虹)",
            "AURORA.GLASS — 玻璃拟态(深蓝紫+极光)",
            "HOLO.PRISM — 全息棱镜(炭灰+渐变描边)"
          ],
          "description": "日志查看器的视觉主题。也可在工具栏的「主题」按钮中临时切换。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run lint && npm run compile && npm test",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test test/*.test.cjs",
    "lint": "eslint src --ext ts",
    "build": "npm run compile",
    "dev": "npm run watch",
    "clean": "rimraf out",
    "rebuild": "npm run clean; npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44"
  }
}
